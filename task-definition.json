{
  "family": "vulnwatch-api-task",
  "taskRoleArn": "arn:aws:iam::012834916544:role/ecsTaskExecutionRole",
  "executionRoleArn": "arn:aws:iam::012834916544:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "revision": 27,
  "volumes": [],
  "status": "ACTIVE",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "1024",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "containerDefinitions": [
    {
      "name": "vulnwatch-api",
      "image": "012834916544.dkr.ecr.eu-north-1.amazonaws.com/vulnwatch:api-dev-b54517da641a71bb198f631b5c8a60af70b4183f",
      "cpu": 0,
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp",
          "name": "vulnwatch-api-task-80-tcp",
          "appProtocol": "http"
        }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:8080/api/health || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "environment": [
        {
          "name": "ASPNETCORE_ENVIRONMENT",
          "value": "Production"
        },
        {
          "name": "ASPNETCORE_URLS",
          "value": "http://+:8080"
        },
        {
          "name": "Jwt__Issuer",
          "value": "FourteenAPI"
        },
        {
          "name": "Jwt__Audience",
          "value": "FourteenAPI"
        },
        {
          "name": "Jwt__ExpireInMinute",
          "value": "15"
        },
        {
          "name": "Jwt__RefreshTokenExpiryDays",
          "value": "7"
        },
        {
          "name": "FrontendUrl__path",
          "value": "https://staging.vuln-watch.hng14.com"
        },
        {
          "name": "FrontendUrl__Verify",
          "value": "https://staging.vuln-watch.hng14.com/auth/verify"
        },
        {
          "name": "FrontendUrl__ForgotPassword",
          "value": "https://staging.vuln-watch.hng14.com/auth/forgot-password"
        },
        {
          "name": "Logging__LogLevel__Default",
          "value": "Information"
        },
        {
          "name": "Logging__LogLevel__Microsoft.AspNetCore",
          "value": "Warning"
        },
        {
          "name": "SmtpCredentials__FromName",
          "value": "VulnWatch"
        },
        {
          "name": "SmtpCredentials__Host",
          "value": "smtp.gmail.com"
        },
        {
          "name": "SmtpCredentials__Port",
          "value": "587"
        }
      ],
      "secrets": [
        {
          "name": "ConnectionStrings__DefaultConnection",
          "valueFrom": "arn:aws:ssm:eu-north-1:012834916544:parameter/fourteen/production/ConnectionStrings__DefaultConnection"
        },
        {
          "name": "Redis__Configuration",
          "valueFrom": "arn:aws:ssm:eu-north-1:012834916544:parameter/fourteen/production/ConnectionStrings__RedisConnection"
        },
        {
          "name": "Jwt__SecretKey",
          "valueFrom": "arn:aws:ssm:eu-north-1:012834916544:parameter/fourteen/production/Jwt__SecretKey"
        },
        {
          "name": "GitHub__ClientId",
          "valueFrom": "arn:aws:ssm:eu-north-1:012834916544:parameter/fourteen/production/GitHub__ClientId"
        },
        {
          "name": "GitHub__ClientSecret",
          "valueFrom": "arn:aws:ssm:eu-north-1:012834916544:parameter/fourteen/production/GitHub__ClientSecret"
        },
        {
          "name": "Authentication__Google__ClientId",
          "valueFrom": "arn:aws:ssm:eu-north-1:012834916544:parameter/fourteen/production/Google__ClientId"
        },
        {
          "name": "Authentication__Google__ClientSecret",
          "valueFrom": "arn:aws:ssm:eu-north-1:012834916544:parameter/fourteen/production/Google__ClientSecret"
        },
        {
          "name": "SmtpCredentials__Username",
          "valueFrom": "arn:aws:ssm:eu-north-1:012834916544:parameter/fourteen/production/SmtpCredentials__Username"
        },
        {
          "name": "SmtpCredentials__Password",
          "valueFrom": "arn:aws:ssm:eu-north-1:012834916544:parameter/fourteen/production/SmtpCredentials__Password"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/vulnwatch-api-task",
          "awslogs-create-group": "true",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "environmentFiles": [],
      "mountPoints": [],
      "volumesFrom": [],
      "ulimits": [],
      "systemControls": []
    }
  ]
}
